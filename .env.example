# Dam Water Level Calibration Constants
# These values define what 100% dam level corresponds to in real units

# Maximum depth when dam is at 100% (in meters)
VITE_DAM_MAX_DEPTH_M=50

# Maximum volume when dam is at 100% (in Million Cubic Meters - MCM)
VITE_DAM_MAX_VOLUME_MCM=1000

# API Configuration
VITE_APP_URL=http://localhost:5000